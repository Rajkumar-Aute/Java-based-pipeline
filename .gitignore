# Java & Maven Artifacts
# Do not commit compiled code or build directories.

target/
*.class
*.jar
*.war
*.ear
*.nar
*.log

# Maven specific temporary files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# Ignore the Maven wrapper jar, but keep the wrapper scripts (mvnw, mvnw.cmd)
.mvn/wrapper/maven-wrapper.jar


# Integrated Development Environment (IDE) Files
# Developers use different IDEs; keep local configurations out of source control.

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# Visual Studio Code
.vscode/


# Operating System Files
# Prevent OS-specific thumbnail caches and directory settings from merging.

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini


# Security & Secrets (DevSecOps Core)
# NEVER commit credentials, private keys, or local environment overrides.

*.pem
*.key
.env
.env.local
*-secret.properties
application-secret.yml
application-secret.properties